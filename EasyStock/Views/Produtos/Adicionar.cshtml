@model EasyStock.Models.Produto

@{
    ViewData["Title"] = Model.Id == 0 ? "Cadastrar Produto" : "Editar Produto";
}

<div class="text-center">
    <h1 class="display-4">@ViewData["Title"]</h1>
</div>

<section class="form-container-p">
    <form asp-action="@(Model.Id == 0 ? "Adicionar" : "Editar")" method="post" class="product-form">
        <div class="product-name">
            <label for="Nome">Nome</label>
            <input type="text" id="Nome" name="Nome" value="@Model.Nome" required />
            @if (!string.IsNullOrEmpty(ViewData["NomeError"]?.ToString()))
            {
                <span>@ViewData["NomeError"]</span>
            }
        </div>

        <div class="product-quantidade-preco">
            <div>
                <label for="Quantidade">Quantidade</label>
                <input type="number" id="Quantidade" name="Quantidade" value="@Model.Quantidade" required />
            </div>
            <div>
                <label for="Preco">Preço</label>
                <input type="number" id="Preco" name="Preco" value="@Model.Preco.ToString("0.##")" step="0.01" />
            </div>
        </div>

        <div>
            <label for="Descricao">Descrição</label>
            <textarea id="Descricao" name="Descricao">@Model.Descricao</textarea>
        </div>

        <!-- Texto do botão adaptável para Adicionar ou Atualizar -->
        <button type="submit">@((Model.Id == 0) ? "Adicionar Produto" : "Atualizar Produto")</button>
    </form>
</section>
