@{
    Layout = null;
}

<head>
    <title>EasyStock - Login</title>
    <link href="~/css/styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>

<div class="container">
    <div class="form-container">
        <div class="navbar-brand-a">
            <i class="fas fa-box-open me-2"></i>EasyStock
        </div>
        <h2>Login</h2>
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <input id="username" name="username" type="text" class="form-control" placeholder="Email" required />
            </div>

            <div class="mb-3">
                <input id="password" name="password" type="password" class="form-control" placeholder="Senha" required />
            </div>

            <button type="submit" class="btn btn-primary">Entrar</button>
        </form>

        @if (ViewBag.Error != null)
        {
            <div class="alert">@ViewBag.Error</div>
        }

        <div class="text-center">
            <p>Não tem uma conta? <a href="@Url.Action("Register", "User")">Cadastre-se</a></p>
        </div>
    </div>
</div>

